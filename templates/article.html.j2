<!doctype html>
<html lang="en">

<head>
  {% set title = blog_post.title %}
  {% include "head_common.html.j2" %}

  {% if blog_post.description -%}
  <meta name="description" content="{{ blog_post.description }}">
  {% endif -%}
  <meta name="author" content="{{ blog_post.author }}">
  <meta property="article:published_time" content="{{ blog_post.creation_dt }}">
  <meta property="article:modified_time" content="{{ blog_post.last_update_dt }}">
</head>

<body>
  <header>
    {% set author_name = blog_post.author %}
    {% include "navbar.html.j2" %}
    <h1>{{ blog_post.title }}</h1>
    <p>
      {% if blog_post.description -%}
      {{ blog_post.description }}<br />
      {%- endif %}
      <small>
        Last updated on {{ blog_post.human_time }}
      </small>
    </p>
  </header>
  <main>
    {{ main_content | safe }}
  </main>
  {% set author_name = blog_post.author %}
  {% include "footer.html.j2" %}
</body>

</html>